{
  "name": "fuer-yang-academic-site",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "description": "Fuer Yang academic homepage (Hugo Blox)",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide"
    ],
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide"
    ]
  },
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "PATH=\"$(pwd)/node_modules/.bin:$PATH\" hugo --minify && pnpm run pagefind",
    "deploy": "bash deploy.sh",
    "pagefind": "pagefind --site public"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.12",
    "@tailwindcss/typography": "^0.5.10",
    "pagefind": "^1.4.0",
    "preact": "^10.27.2",
    "tailwindcss": "^4.1.12"
  }
}
